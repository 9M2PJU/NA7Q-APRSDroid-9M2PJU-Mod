<?xml version="1.0" encoding="utf-8"?>
<!--
  Winlink action buttons — shown above the message list when the
  conversation is with WLNK-1. Inflated and inserted dynamically by
  MessageActivity when targetcall is WLNK-1.
-->
<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/winlink_buttons"
android:layout_width="fill_parent"
android:layout_height="wrap_content"
android:orientation="horizontal"
android:padding="4dp"
android:background="#222" >

<TextView android:id="@+id/winlink_status"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:layout_gravity="center_vertical"
android:layout_weight="1"
android:text="@string/winlink_status_logged_out"
android:textColor="#ccc"
android:textSize="12sp"
android:paddingLeft="6dp" />

<Button android:id="@+id/winlink_btn_login"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="@string/winlink_login"
android:textSize="12sp"
android:minWidth="48dp" />

<Button android:id="@+id/winlink_btn_list"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="@string/winlink_list"
android:textSize="12sp"
android:minWidth="48dp" />

<Button android:id="@+id/winlink_btn_compose"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="@string/winlink_compose"
android:textSize="12sp"
android:minWidth="48dp" />

<Button android:id="@+id/winlink_btn_logout"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="@string/winlink_logout"
android:textSize="12sp"
android:minWidth="48dp" />

</LinearLayout>

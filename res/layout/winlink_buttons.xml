<?xml version="1.0" encoding="utf-8"?>
<!--
  Winlink APRSLink action buttons — shown above the message list when
  the conversation is with WLNK-1. Horizontal scrollable strip with the
  most useful APRSLink commands.

  Commands (per https://winlink.org/APRSLink):
    Session:  Login, Logout
    Messages: List(L), Read(R#), Reply(Y#), Compose(SP), Forward(F#), Delete(K#)
    Info:     Help(H)
-->
<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:id="@+id/winlink_buttons"
android:layout_width="fill_parent"
android:layout_height="wrap_content"
android:orientation="vertical"
android:background="#222" >

	<!-- Status row -->
	<LinearLayout
	android:layout_width="fill_parent"
	android:layout_height="wrap_content"
	android:orientation="horizontal"
	android:padding="4dp" >

		<TextView android:id="@+id/winlink_status"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_gravity="center_vertical"
		android:layout_weight="1"
		android:text="@string/winlink_status_logged_out"
		android:textColor="#ccc"
		android:textSize="12sp"
		android:paddingLeft="6dp" />

		<Button android:id="@+id/winlink_btn_login"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/winlink_login"
		android:textSize="12sp"
		android:minWidth="48dp" />

		<Button android:id="@+id/winlink_btn_logout"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:text="@string/winlink_logout"
		android:textSize="12sp"
		android:minWidth="48dp" />
	</LinearLayout>

	<!-- Scrollable command buttons -->
	<HorizontalScrollView
	android:layout_width="fill_parent"
	android:layout_height="wrap_content"
	android:scrollbars="none" >

		<LinearLayout
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:orientation="horizontal"
		android:padding="4dp" >

			<Button android:id="@+id/winlink_btn_help"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_help"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_list"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_list"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_read"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_read"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_reply"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_reply"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_compose"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_compose"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_forward"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_forward"
			android:textSize="11sp"
			android:minWidth="40dp" />

			<Button android:id="@+id/winlink_btn_kill"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/winlink_kill"
			android:textSize="11sp"
			android:minWidth="40dp" />

		</LinearLayout>
	</HorizontalScrollView>
</LinearLayout>

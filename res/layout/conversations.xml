<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	android:layout_width="fill_parent"
	android:layout_height="fill_parent"
	android:orientation="vertical"
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	>
	<ListView
		android:id="@android:id/list"
		android:layout_width="fill_parent"
		android:layout_height="100sp"
		android:layout_weight="1"
		android:focusable="true"
		android:focusableInTouchMode="true"
		android:descendantFocusability="blocksDescendants"
		/>
	<TextView
		android:id="@android:id/empty"
		android:layout_width="fill_parent" 
		android:layout_height="100sp"
		android:layout_weight="2"
		android:textSize="18sp"
		android:text="@string/msg_empty_list"/>
	<!-- New conversation button — full width on top -->
	<Button
		android:id="@+id/new_conversation"
		android:layout_width="fill_parent"
		android:layout_height="wrap_content"
		android:text="@string/msg_send_new"
		android:textSize="12sp"
		android:padding="6dp"
		/>
	<!-- Service buttons in a 3x3 grid -->
	<androidx.gridlayout.widget.GridLayout
		android:id="@+id/service_buttons_grid"
		android:layout_width="fill_parent"
		android:layout_height="wrap_content"
		android:padding="2dp"
		app:columnCount="3"
		app:rowCount="3"
		app:orientation="horizontal"
		>
		<Button
			android:id="@+id/winlink_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p_winlink"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/wtsapp_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__wtsapp"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/bot_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__bot"
			android:textSize="10sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/aprsmy_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__aprsmy"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/mailmy_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__mailmy"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/repeat_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__repeat"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/callmy_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__callmy"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/bbsmy_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__bbsmy"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
		<Button
			android:id="@+id/gamemy_conversation"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			app:layout_columnWeight="1"
			
			app:layout_gravity="fill_horizontal"
			android:text="@string/p__gamemy"
			android:textSize="11sp"
			android:maxLines="1"
			android:ellipsize="end"
			android:padding="4dp"
			android:minHeight="48dp"
			/>
	</androidx.gridlayout.widget.GridLayout>
	<com.google.android.material.bottomnavigation.BottomNavigationView
		android:id="@+id/bottom_nav"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:menu="@menu/bottom_nav_menu"
		app:labelVisibilityMode="labeled"
		android:background="@color/md_background"
		/>
</LinearLayout>

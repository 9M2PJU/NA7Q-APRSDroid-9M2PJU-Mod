<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================
         AppTheme — Material 3-inspired design system on top of
         Material Components 1.9.0 (M2). We can't use the Material3
         library (requires compileSdk 34+; we're at 33), but we apply
         M3 design principles: tonal color palette, shape theming,
         surface elevation, refined typography, and modern component
         styles.

         Navy primary + amber accent. Dark-only (no light theme).
         Works with AppCompatActivity, framework Activity,
         ListActivity, and PreferenceActivity.
         ============================================================ -->
    <style name="AppTheme"
           parent="Theme.MaterialComponents">

        <!-- ===== Core colors ===== -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>
        <item name="colorAccent">@color/md_accent</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>

        <!-- ===== Surfaces ===== -->
        <item name="android:colorBackground">@color/md_background</item>
        <item name="android:textColorPrimary">@color/md_text_primary</item>
        <item name="android:textColorSecondary">@color/md_text_secondary</item>
        <item name="android:textColorTertiary">@color/md_text_hint</item>
        <item name="android:textColorHint">@color/md_text_hint</item>

        <!-- ===== Component styles ===== -->
        <item name="materialButtonStyle">@style/Widget.AppTheme.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.AppTheme.Button.TextButton</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.AppTheme.BottomSheetDialog</item>

        <!-- ===== Action bar as modern top app bar ===== -->
        <item name="android:actionBarStyle">@style/Widget.AppTheme.ActionBar</item>
        <item name="actionBarStyle">@style/Widget.AppTheme.ActionBar</item>
        <item name="android:actionBarTheme">@style/ThemeOverlay.AppTheme.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.AppTheme.ActionBar</item>

        <!-- ===== System bars ===== -->
        <item name="android:statusBarColor">@color/md_status_bar</item>
        <item name="android:navigationBarColor">@color/md_navigation_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">@bool/light_nav_bar_icons</item>
        <!-- Don't draw content in the display cutout / under-display camera area -->
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>
        <!--
             windowDrawsSystemBarBackgrounds=false: the system applies
             window insets as padding to the content automatically (pre-
             edge-to-edge behavior). This is inherited by dialog windows
             (PreferenceScreen sub-screens), which DON'T get the runtime
             setDecorFitsSystemWindows(false) override that the activity's
             own window gets. So dialogs get non-edge-to-edge behavior
             from the theme, while the activity gets edge-to-edge from
             the runtime call. This fixes the "Incoming Messages" header
             bleeding under the status bar on Android 15/16.
        -->
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>

        <!-- ===== Dialogs ===== -->
        <item name="alertDialogTheme">@style/ThemeOverlay.AppTheme.Dialog</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.AppTheme.Dialog</item>

        <!-- Disable activity transition animations (no sliding between screens) -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- ============================================================
         SplashTheme — launcher splash. No action bar, black window
         background. The splash image is shown via an ImageView in
         splash.xml (setContentView), which uses centerCrop for
         perfect fit without distortion.
         ============================================================ -->
    <style name="SplashTheme"
           parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>
    </style>

    <!-- ============================================================
         MapViewTheme — dark Material theme for the map activities.
         Uses Theme.MaterialComponents (required by BottomNavigationView
         and other Material components). Matches AppTheme so the bottom
         navigation bar has the same dark background on all screens.
         MapsForge works fine with this.
         ============================================================ -->
    <style name="MapViewTheme"
           parent="Theme.MaterialComponents">
        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:actionBarStyle">@style/Map.ActionBar</item>
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorPrimaryDark">@color/md_primary_dark</item>
        <item name="colorAccent">@color/md_accent</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="android:windowBackground">@color/md_background</item>
        <item name="android:statusBarColor">@color/md_status_bar</item>
        <item name="android:navigationBarColor">@color/md_navigation_bar</item>
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Map.ActionBar"
           parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="android:background">#a0000000</item>
    </style>

</resources>

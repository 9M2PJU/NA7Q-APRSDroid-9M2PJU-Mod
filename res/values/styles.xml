<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================================
         SHAPE APPEARANCES — Material 3-style rounded corners
         ============================================================ -->

    <style name="ShapeAppearance.AppTheme.SmallComponent"
           parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_small</item>
    </style>

    <style name="ShapeAppearance.AppTheme.MediumComponent"
           parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_medium</item>
    </style>

    <style name="ShapeAppearance.AppTheme.LargeComponent"
           parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/shape_corner_large</item>
    </style>

    <!-- ============================================================
         BUTTONS
         ============================================================ -->

    <!-- Filled button — amber accent, navy text. Primary action. -->
    <style name="Widget.AppTheme.Button"
           parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/md_accent</item>
        <item name="android:textColor">@color/md_on_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:elevation">@dimen/elevation_low</item>
        <item name="rippleColor">@color/md_on_accent</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="iconTint">@color/md_on_accent</item>
    </style>

    <!-- Tonal button — secondary container color. Secondary action. -->
    <style name="Widget.AppTheme.Button.TonalButton"
           parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/md_secondary_container</item>
        <item name="android:textColor">@color/md_on_secondary_container</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="rippleColor">@color/md_on_secondary_container</item>
        <item name="iconTint">@color/md_on_secondary_container</item>
    </style>

    <!-- Outlined button — transparent bg, outline border. -->
    <style name="Widget.AppTheme.Button.OutlinedButton"
           parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/md_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="strokeColor">@color/md_outline</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="rippleColor">@color/md_primary</item>
        <item name="iconTint">@color/md_primary</item>
    </style>

    <!-- Text button — no background, accent text. Low-emphasis action. -->
    <style name="Widget.AppTheme.Button.TextButton"
           parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/md_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="rippleColor">@color/md_accent</item>
        <item name="iconTint">@color/md_accent</item>
    </style>

    <!-- ============================================================
         TEXT INPUT — outlined box (M3 style)
         ============================================================ -->

    <style name="Widget.AppTheme.TextInputLayout.OutlinedBox"
           parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/md_accent</item>
        <item name="boxBackgroundColor">@color/md_surface</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_text_field</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_text_field</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_text_field</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_text_field</item>
        <item name="hintTextColor">@color/md_accent</item>
        <item name="android:textColorHint">@color/md_text_hint</item>
    </style>

    <!-- ============================================================
         ACTION BAR — modern top app bar
         Surface-colored, no elevation, clean typography.
         ============================================================ -->

    <style name="Widget.AppTheme.ActionBar"
           parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="android:background">@color/md_surface</item>
        <item name="android:elevation">@dimen/actionbar_elevation</item>
        <item name="android:titleTextStyle">@style/TextAppearance.AppTheme.ActionBar.Title
        </item>
        <item name="android:height">@dimen/actionbar_height</item>
        <item name="background">@color/md_surface</item>
        <item name="elevation">@dimen/actionbar_elevation</item>
        <item name="titleTextStyle">@style/TextAppearance.AppTheme.ActionBar.Title</item>
        <item name="height">@dimen/actionbar_height</item>
    </style>

    <!-- Action bar overlay theme — tint icons and text for surface bg -->
    <style name="ThemeOverlay.AppTheme.ActionBar"
           parent="ThemeOverlay.MaterialComponents.ActionBar.Surface">
        <item name="android:textColorPrimary">@color/md_on_surface</item>
        <item name="colorControlNormal">@color/md_on_surface</item>
    </style>

    <!-- ============================================================
         DIALOGS — Material alert dialog with rounded corners
         ============================================================ -->

    <style name="ThemeOverlay.AppTheme.Dialog"
           parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorSecondary">@color/md_accent</item>
        <item name="colorAccent">@color/md_accent</item>
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:textColorPrimary">@color/md_on_surface</item>
        <item name="buttonBarPositiveButtonStyle">
            @style/Widget.AppTheme.Dialog.Button.Positive
        </item>
        <item name="buttonBarNegativeButtonStyle">
            @style/Widget.AppTheme.Dialog.Button.Negative
        </item>
    </style>

    <style name="Widget.AppTheme.Dialog.Button.Positive"
           parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.AppTheme.Dialog.Button.Negative"
           parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/md_text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ============================================================
         BOTTOM SHEET — rounded top corners
         ============================================================ -->

    <style name="ThemeOverlay.AppTheme.BottomSheetDialog"
           parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.AppTheme.BottomSheet</item>
    </style>

    <style name="Widget.AppTheme.BottomSheet"
           parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">
            @style/ShapeAppearance.AppTheme.BottomSheet
        </item>
        <item name="backgroundTint">@color/md_surface</item>
    </style>

    <style name="ShapeAppearance.AppTheme.BottomSheet">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/shape_corner_large</item>
        <item name="cornerSizeTopRight">@dimen/shape_corner_large</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- ============================================================
         TYPOGRAPHY — Material type scale
         ============================================================ -->

    <style name="TextAppearance.AppTheme.ActionBar.Title"
           parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/md_on_surface</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.AppTheme.Headline"
           parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/md_text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AppTheme.Title"
           parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/md_text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AppTheme.Body"
           parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/md_text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.AppTheme.Body.Secondary"
           parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/md_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.AppTheme.Caption"
           parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/md_text_hint</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.AppTheme.Label"
           parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/md_accent</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ============================================================
         CARD — for list items and content containers
         ============================================================ -->

    <style name="Widget.AppTheme.CardView"
           parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/md_surface</item>
        <item name="cardCornerRadius">@dimen/corner_card</item>
        <item name="cardElevation">@dimen/elevation_low</item>
        <item name="contentPadding">@dimen/space_md</item>
        <item name="rippleColor">@color/md_surface_variant</item>
    </style>

    <!-- ============================================================
         Map callsign overlay (used on the map, kept as-is)
         ============================================================ -->
    <style name="MapCallSign">
        <item name="android:typeface">monospace</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#ff000000</item>
        <item name="android:shadowColor">#80c8ffc8</item>
        <item name="android:shadowRadius">3</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:padding">0sp</item>
    </style>

</resources>
